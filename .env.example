APP_ENV=development
DATABASE_URL=sqlite:///./data/ai_frontier_radar.db

LLM_PROFILE=minimax_m27_highspeed_anthropic

MINIMAX_API_KEY=replace-me

# fallback for openai-compatible profile
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=gpt-4o-mini

HTTP_TIMEOUT_SECONDS=20
FETCH_RETRY_COUNT=2
MAX_SOURCE_CHARS=60000
MAX_LLM_INPUT_CHARS=30000

# Chinese one-liner summaries for candidate SourceItems.
# Uses the existing LLM_PROFILE by default.
ONE_LINER_ENABLED=true
ONE_LINER_PROVIDER=llm_profile
ONE_LINER_MAX_PER_RUN=10
ONE_LINER_MAX_PER_DAY=50
ONE_LINER_MAX_INPUT_CHARS=1200
