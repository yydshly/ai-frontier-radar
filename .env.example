# =============================================================================
# AI Frontier Radar — Runtime Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── 1. Basic Runtime ─────────────────────────────────────────────────────────
APP_ENV=development
DATABASE_URL=sqlite:///./data/ai_frontier_radar.db

# ── 2. LLM Profile ────────────────────────────────────────────────────────────
# Active LLM profile name. See config/llm_profiles.example.yaml.
LLM_PROFILE=minimax_m27_highspeed_anthropic

# MiniMax API key used by minimax_* profiles. Never commit real keys.
MINIMAX_API_KEY=replace-me

# ── 3. OpenAI-compatible Fallback ────────────────────────────────────────────
# Used when LLM_PROFILE references an openai-compatible profile.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=gpt-4o-mini

# ── 4. Fetch / Parse Limits ─────────────────────────────────────────────────
HTTP_TIMEOUT_SECONDS=20
FETCH_RETRY_COUNT=2
MAX_SOURCE_CHARS=60000
MAX_LLM_INPUT_CHARS=30000

# ── 5. Chinese One-liner / Lightweight Summary ────────────────────────────────
# Generates Chinese one-liner summaries for SourceItems using LLM_PROFILE.
ONE_LINER_ENABLED=true
ONE_LINER_PROVIDER=llm_profile
ONE_LINER_MAX_PER_RUN=20
ONE_LINER_MAX_PER_DAY=50
ONE_LINER_MAX_INPUT_CHARS=1200

# ── 5b. Radar Daily Scope ───────────────────────────────────────────────────
# These control the user-facing "today" window and item counts.
RADAR_DAILY_WINDOW_HOURS=24          # rolling time window (1–168 hours)
RADAR_DAILY_ITEM_LIMIT=50           # max candidate items in radar (1–200)
RADAR_DAILY_BRIEFING_LIMIT=50       # max items in daily briefing (1–200)
RADAR_TODAY_FOCUS_SIZE=5            # top-N items pinned as "最新发现" (1–20)
RADAR_DAILY_REPORT_READY_THRESHOLD=5 # min readable items before report "ready" (1–50)

# ── 5c. Radar Recommendation ────────────────────────────────────────────────
RADAR_RECOMMENDED_LIMIT=10          # max compile-candidate items (1–50)
RADAR_RECOMMENDED_PER_SOURCE_LIMIT=3 # max candidates per single source (1–10)
RADAR_RECOMMENDED_MAX_SCAN=300      # max items scanned for candidates (10–1000)
RADAR_RECOMMENDED_INSIGHT_LIMIT=9999  # legacy: no longer used for default cap (kept for compat)
RADAR_RECOMMENDED_INSIGHT_HARD_CAP=20 # absolute safety ceiling for one batch trigger (1–100)

# ── 5d. Radar Generation ─────────────────────────────────────────────────────
RADAR_SUMMARY_BATCH_LIMIT=50        # max items queued in one background summary batch

# ── 6. Full-content Summary from HTML Snapshot ────────────────────────────────
# Generates Chinese summaries from saved HTML/text snapshots.
# Keep disabled by default to avoid accidental LLM calls.
LLM_SUMMARY_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_TIMEOUT_SECONDS=30
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_SUMMARY_CHARS=500

# ── 7. Daily Core Report ──────────────────────────────────────────────────────
# LLM-generated daily report. Disabled by default — confirm cost & coverage first.
DAILY_REPORT_ENABLED=false
DAILY_REPORT_MAX_ITEMS=50

# ── 8. Daily Broadcast / TTS ──────────────────────────────────────────────────
# Xiaomi MiMo V2.5 TTS. Keep disabled until the API key is configured.
DAILY_BROADCAST_TTS_ENABLED=false
MIMO_API_KEY=
MIMO_TTS_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_VOICE=冰糖
MIMO_TTS_FORMAT=wav
MIMO_TTS_STYLE=使用清晰、专业、自然的中文新闻播报语气，语速适中，重点明确。
MIMO_TTS_TIMEOUT_SECONDS=180
MIMO_TTS_MAX_TEXT_CHARS=12000
MIMO_TTS_CHUNK_CHARS=3000
DAILY_BROADCAST_AUDIO_DIR=runtime/daily_audio
DAILY_BROADCAST_AUDIO_RETENTION_DAYS=30
DAILY_BROADCAST_AUDIO_MAX_FILES=100
DAILY_BROADCAST_AUDIO_LOCK_MINUTES=30
