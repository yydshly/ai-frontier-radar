# =============================================================================
# AI Frontier Radar — Runtime Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── 1. Basic Runtime ─────────────────────────────────────────────────────────
APP_ENV=development
DATABASE_URL=sqlite:///./data/ai_frontier_radar.db

# ── 2. LLM Profile ────────────────────────────────────────────────────────────
# Active LLM profile name. See config/llm_profiles.example.yaml.
LLM_PROFILE=minimax_m27_highspeed_anthropic

# MiniMax API key used by minimax_* profiles. Never commit real keys.
MINIMAX_API_KEY=replace-me

# ── 3. OpenAI-compatible Fallback ────────────────────────────────────────────
# Used when LLM_PROFILE references an openai-compatible profile.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=gpt-4o-mini

# ── 4. Fetch / Parse Limits ─────────────────────────────────────────────────
HTTP_TIMEOUT_SECONDS=20
FETCH_RETRY_COUNT=2
MAX_SOURCE_CHARS=60000
MAX_LLM_INPUT_CHARS=30000

# ── 5. Chinese One-liner / Lightweight Summary ────────────────────────────────
# Generates Chinese one-liner summaries for SourceItems using LLM_PROFILE.
ONE_LINER_ENABLED=true
ONE_LINER_PROVIDER=llm_profile
ONE_LINER_MAX_PER_RUN=20
ONE_LINER_MAX_PER_DAY=50
ONE_LINER_MAX_INPUT_CHARS=1200

# ── 6. Full-content Summary from HTML Snapshot ────────────────────────────────
# Generates Chinese summaries from saved HTML/text snapshots.
# Keep disabled by default to avoid accidental LLM calls.
LLM_SUMMARY_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_TIMEOUT_SECONDS=30
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_SUMMARY_CHARS=500

# ── 7. Daily Core Report ──────────────────────────────────────────────────────
# LLM-generated daily report. Disabled by default — confirm cost & coverage first.
DAILY_REPORT_ENABLED=false
DAILY_REPORT_MAX_ITEMS=12

# ── 8. Daily Broadcast / TTS ──────────────────────────────────────────────────
# Reserved daily broadcast TTS switch. Does NOT call external TTS by default.
DAILY_BROADCAST_TTS_ENABLED=false
